{
  "manifest_version": 3,
  "name": "Chrysalis",
  "version": "1.0.4",
  "description": "Sync Monarch Money balances to ProjectionLab with one click.",
  "permissions": ["storage", "activeTab", "scripting", "tabs", "alarms"],
  "host_permissions": [
    "https://app.monarch.com/*",
    "https://api.monarch.com/*",
    "https://api.monarchmoney.com/*",
    "https://app.projectionlab.com/*",
    "https://ea.projectionlab.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://app.monarch.com/*"],
      "js": ["content-scripts/monarch.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "setup/setup.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
